{
  "expo": {
    "name": "Secure Notes",
    "slug": "Secure-Notes",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "assets/_Shield_Logo.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/_Shield_Logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/_Shield_Logo.png",
        "backgroundImage": "./assets/_Shield_Logo.png",
        "monochromeImage": "./assets/_Shield_Logo.png"
      },
      "package": "com.rajuyadav07.SecureNotes"
    },
    "web": {
      "favicon": "./assets/_Shield_Logo.png"
    },
    "plugins": [
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      "expo-mail-composer",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "9a25614c-a383-43fc-a78d-c61022f73adc"
      }
    }
  }
}
